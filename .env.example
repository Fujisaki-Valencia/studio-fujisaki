# =========================================================
# Studio Fujisaki — local environment (COPY to .env)
# NEVER commit the real .env. It is git-ignored on purpose.
# The upload-r2 script reads these values from the environment.
# =========================================================

# Cloudflare R2 (S3-compatible) credentials
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket the full-size pc.jpg / sp.jpg files are uploaded to
R2_BUCKET=studio-fujisaki

# Public base URL that serves the bucket (must match CONFIG.R2_BASE_URL in config.js)
# e.g. https://wallpapers.studio-fujisaki.com  or  https://<hash>.r2.dev
R2_PUBLIC_BASE_URL=https://pub-d55846f181c2469888431e86756175c8.r2.dev

# S3 API endpoint for R2 (usually https://<account_id>.r2.cloudflarestorage.com)
R2_ENDPOINT=
