# --- Secrets: never commit ---
.env
.env.*
!.env.example

# --- Full-size images live in external storage (R2), NOT in git ---
# Keep only lightweight thumbs/ in the repo.
originals/
fullsize/
uploads/
*.psd

# --- Pinterest pin images: upload-only, regenerate with scripts/gen-pin.js ---
# They are never served by the site, so there is no reason to carry them in git.
pins/

# --- Node ---
node_modules/
npm-debug.log*
yarn-error.log*

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.vscode/
.idea/
